tf_models/
*.h5
*.keras
*.pkl
*.joblib
saved_model/

# ── Cobertura y testing ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ── Distribución / build ──────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
.pyright/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverrideDirectory

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

