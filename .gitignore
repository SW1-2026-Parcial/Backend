# ── Entorno virtual ───────────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Variables de entorno (credenciales) ───────────────────────────────────────
.env
.env.local
.env.production
# .env.example SÍ se sube — es la plantilla sin valores reales

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

